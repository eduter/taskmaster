{
    "$schema": "https://biomejs.dev/schemas/2.4.15/schema.json",
    "files": {
        "includes": ["bin/**/*.ts", "gateway/src/**/*.ts", "skills/**/*.ts"]
    },
    "formatter": {
        "enabled": true,
        "indentStyle": "space",
        "indentWidth": 4,
        "lineWidth": 120,
        "lineEnding": "lf"
    },
    "javascript": {
        "formatter": {
            "quoteStyle": "single",
            "trailingCommas": "es5",
            "semicolons": "always",
            "arrowParentheses": "always"
        }
    },
    "linter": {
        "enabled": true,
        "rules": {
            "recommended": true,
            "style": {
                "useBlockStatements": "error",
                "noNonNullAssertion": "error"
            },
            "suspicious": {
                "noExplicitAny": "error",
                "noTemplateCurlyInString": "off"
            },
            "correctness": {
                "noUnusedVariables": "error",
                "noUnusedImports": "error"
            }
        }
    },
    "overrides": [
        {
            "includes": ["**/*.test.ts"],
            "linter": {
                "rules": {
                    "style": {
                        "noNonNullAssertion": "off"
                    }
                }
            }
        }
    ]
}
